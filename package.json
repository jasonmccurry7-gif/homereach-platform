{
  "name": "homereach",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "archive:market-capture-qa": "node scripts/market-capture-archive-qa-records.mjs",
    "activate:market-capture": "node scripts/market-capture-revenue-activation.mjs",
    "monitor:market-capture": "node scripts/market-capture-go-live-monitor.mjs",
    "monitor:market-capture:first-customer": "node scripts/market-capture-first-customer-monitor.mjs",
    "smoke:foundation": "node scripts/foundation-smoke.mjs",
    "smoke:phase-a": "node scripts/foundation-smoke.mjs",
    "smoke:market-capture-live-funnel": "node scripts/market-capture-live-funnel-smoke.mjs",
    "smoke:market-capture-stripe": "node scripts/verify-market-capture-stripe.mjs",
    "smoke:market-capture-stripe:checkout": "node scripts/verify-market-capture-stripe.mjs --create-expire-checkout --allow-live",
    "smoke:political-district": "node scripts/political-district-live-funnel-smoke.mjs",
    "smoke:targeted-direct-mail": "node scripts/targeted-direct-mail-live-funnel-smoke.mjs",
    "smoke:shared-postcards": "node scripts/shared-postcards-live-funnel-smoke.mjs",
    "smoke:cost-savings-review": "node scripts/cost-savings-review-live-funnel-smoke.mjs",
    "smoke:reputation-follow-up": "node scripts/reputation-follow-up-live-funnel-smoke.mjs",
    "smoke:local-growth-review": "node scripts/local-growth-review-live-funnel-smoke.mjs",
    "smoke:local-seo": "node scripts/local-seo-live-funnel-smoke.mjs",
    "smoke:social-content": "node scripts/social-content-live-funnel-smoke.mjs",
    "smoke:ai-website-assistant": "node scripts/ai-website-assistant-live-funnel-smoke.mjs",
    "smoke:contractos": "node scripts/contractos-live-funnel-smoke.mjs",
    "smoke:ai-coo": "node scripts/ai-coo-live-smoke.mjs",
    "smoke:business-memory": "node scripts/business-memory-live-smoke.mjs",
    "smoke:growth-intelligence": "node scripts/growth-intelligence-live-smoke.mjs",
    "smoke:agent-mini-apps": "node --experimental-strip-types --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/agent-mini-apps-lifecycle-smoke.mjs",
    "preflight:agent-mini-apps-db": "node scripts/agent-mini-apps-db-preflight.mjs",
    "dry-run:agent-mini-apps-migration": "node scripts/agent-mini-apps-migration-dry-run.mjs",
    "apply:agent-mini-apps-migration": "node scripts/agent-mini-apps-migration-apply.mjs",
    "smoke:agent-mini-apps-db": "node scripts/agent-mini-apps-db-hardening-smoke.mjs",
    "smoke:service-catalog": "node scripts/service-catalog-smoke.mjs",
    "type-check": "turbo type-check",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:studio": "cd packages/db && npx drizzle-kit studio",
    "clean": "turbo clean && find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "prettier": "^3.4.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
