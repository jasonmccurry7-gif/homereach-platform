# ─────────────────────────────────────────────────────────────────────────────
# HomeReach — Production Environment Variables
# Deploy target: Vercel  |  Domain: home-reach.com
#
# Add ALL of these to Vercel → Project Settings → Environment Variables
# Set environment to: Production (and Preview if you want staging)
#
# DO NOT commit real credentials. This file is a template only.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://home-reach.com
NEXT_PUBLIC_APP_NAME=HomeReach

# HomeReach Operating System foundation flags
# Keep these explicit in production so each pillar can be paused independently.
ENABLE_HOME_REACH_OS=true
ENABLE_REVENUE_ENGINE=true
ENABLE_CLIENT_COMMAND_CENTER=true
ENABLE_ADMIN_COMMAND_CENTER=true
ENABLE_DIRECT_MAIL_DIGITAL_BUNDLE=true
ENABLE_SUPPLYFY_MODULE=true
ENABLE_POLITICAL_MODULE=true
ENABLE_REVIEW_ENGINE=true
ENABLE_REFERRAL_ENGINE=true
ENABLE_AI_CAMPAIGN_BUILDER=true
ENABLE_AI_REVENUE_OFFICER=true

# ── Database (Supabase) ───────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → Database
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-1-us-east-2.pooler.supabase.com:5432/postgres
DATABASE_URL_POOLED=postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-1-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get from: Stripe Dashboard → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxx
# Get from: Stripe Dashboard → Developers → Webhooks
# Webhook endpoint URL: https://home-reach.com/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# ContractOS Stripe products/prices
STRIPE_CONTRACTOS_WATCHTOWER_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxx
STRIPE_CONTRACTOS_WORKSPACE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxx
STRIPE_CONTRACTOS_PROPOSAL_ASSIST_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxx
STRIPE_CONTRACTOS_MANAGED_BID_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxx
# Optional fixed recurring monthly Price for Market Capture Starter ($499/mo).
# If this is blank, checkout safely falls back to dynamic Stripe price_data.
STRIPE_MARKET_CAPTURE_PRICE_ID=

