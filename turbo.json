{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "DATABASE_URL",
    "DATABASE_URL_POOLED",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "TWILIO_ACCOUNT_SID",
    "TWILIO_AUTH_TOKEN",
    "TWILIO_PHONE_NUMBER",
    "MAILGUN_API_KEY",
    "MAILGUN_DOMAIN",
    "MAILGUN_FROM_EMAIL",
    "MAILGUN_FROM_NAME",
    "RESEND_API_KEY",
    "RESEND_FROM_EMAIL",
    "RESEND_FROM_NAME",
    "POSTMARK_API_TOKEN",
    "POSTMARK_FROM_EMAIL",
    "POSTMARK_FROM_NAME",
    "POSTMARK_MESSAGE_STREAM",
    "ENABLE_POSTMARK_WEBHOOK",
    "POSTMARK_WEBHOOK_USER",
    "POSTMARK_WEBHOOK_PASSWORD",
    "EMAIL_PROVIDER",
    "OWNER_NAME",
    "OWNER_CELL_PHONE",
    "OWNER_PERSONAL_EMAIL",
    "OWNER_SECONDARY_EMAIL",
    "OWNER_DOMAIN_EMAIL",
    "DEFAULT_FROM_EMAIL",
    "DEFAULT_REPLY_TO_EMAIL",
    "OUTREACH_TEST_MODE",
    "OUTREACH_MANUAL_APPROVAL_MODE",
    "OUTREACH_SMS_PROSPECTING_LIVE_ENABLED",
    "OUTREACH_SMS_FROM_NUMBER",
    "OUTREACH_TWILIO_MESSAGING_SERVICE_SID",
    "OUTREACH_DEFAULT_TIME_ZONE",
    "OUTREACH_WEEKDAY_ONLY",
    "OUTREACH_BUSINESS_START_MINUTES",
    "OUTREACH_BUSINESS_END_MINUTES",
    "OUTREACH_DAILY_SMS_CAP",
    "OUTREACH_DAILY_EMAIL_CAP_PER_SENDER",
    "OUTREACH_EMAIL_ROTATION_ENABLED",
    "OUTREACH_AUTOMATION_BATCH_LIMIT",
    "NEXT_PUBLIC_APP_URL",
    "NEXT_PUBLIC_APP_NAME",
    "USE_MOCK_DB",
    "ADMIN_DEV_BYPASS",
    "ADMIN_SYSTEM_USER_ID",
    "ADMIN_NOTIFICATION_EMAIL",
    "NODE_ENV",
    "CRON_SECRET",
    "SERP_API",
    "HUNTER",
    "FACEBOOK_WEBHOOK_VERIFY_TOKEN",
    "FACEBOOK_APP_ID",
    "FACEBOOK_APP_SECRET",
    "FACEBOOK_PAGE_ACCESS_TOKEN",
    "FACEBOOK_PAGE_ID",
    "APEX_COMMAND_NUMBER",
    "APEX_APPROVED_SENDER",
    "ENABLE_INTERNAL_ALERTS",
    "ALERT_SHADOW_MODE",
    "ENABLE_OPERATOR_DASHBOARD",
    "ENABLE_AGENT_MOBILE",
    "JASON_AGENT_ID",
    "NEXTAUTH_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "type-check": {
      "dependsOn": ["^type-check"]
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
