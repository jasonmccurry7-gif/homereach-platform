# ─────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres URL (for Drizzle migrations — uses connection pooler)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL_POOLED=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ─────────────────────────────────────────────
# Stripe
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─────────────────────────────────────────────
# Twilio (SMS)
# ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_MESSAGING_SERVICE_SID=MGxxxx   # optional, preferred over single number

# ─────────────────────────────────────────────
# Mailgun (Email) — primary email provider
# ─────────────────────────────────────────────
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_FROM_EMAIL=no-reply@yourdomain.com
MAILGUN_FROM_NAME=HomeReach

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=HomeReach

# ─────────────────────────────────────────────
# Internal / Admin
# ─────────────────────────────────────────────
# Single admin address for operational notifications (new leads, intake, etc.)
ADMIN_NOTIFICATION_EMAIL=admin@yourdomain.com
# Comma-separated list of admin emails for access control
ADMIN_EMAILS=admin@yourdomain.com
USE_MOCK_DB=false
