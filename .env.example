# ─────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
POSTCARD_DESIGN_BUCKET=postcard-designs

# Direct Postgres URL (for Drizzle migrations — uses connection pooler)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL_POOLED=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ─────────────────────────────────────────────
# Stripe
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─────────────────────────────────────────────
# Twilio (SMS)
# ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
OUTREACH_SMS_FROM_NUMBER=+13302069639
TWILIO_MESSAGING_SERVICE_SID=MGxxxx   # optional, preferred over single number

# ─────────────────────────────────────────────
# Resend (Email)
# ─────────────────────────────────────────────
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=no-reply@home-reach.com
RESEND_FROM_NAME=HomeReach

# Owner / outreach identity
OWNER_NAME=Jason McCurry
OWNER_CELL_PHONE=+13302069639
OWNER_PERSONAL_EMAIL=Jasonmccurry7@gmail.com
OWNER_SECONDARY_EMAIL=Livetogivemarketing@gmail.com
OWNER_DOMAIN_EMAIL=Jason@home-reach.com
DEFAULT_FROM_EMAIL=Jason@home-reach.com
DEFAULT_REPLY_TO_EMAIL=Jason@home-reach.com
EMAIL_PROVIDER=resend
POSTMARK_API_TOKEN=server-token-if-EMAIL_PROVIDER-postmark
POSTMARK_FROM_EMAIL=Jason@home-reach.com
POSTMARK_FROM_NAME=Jason McCurry
POSTMARK_MESSAGE_STREAM=outbound
ENABLE_POSTMARK_WEBHOOK=true
POSTMARK_WEBHOOK_USER=postmark-webhook-user
POSTMARK_WEBHOOK_PASSWORD=postmark-webhook-password

# Conservative outbound controls
OUTREACH_TEST_MODE=false
OUTREACH_MANUAL_APPROVAL_MODE=false
OUTREACH_SMS_PROSPECTING_LIVE_ENABLED=false
OUTREACH_DEFAULT_TIME_ZONE=America/New_York
OUTREACH_WEEKDAY_ONLY=true
OUTREACH_BUSINESS_START_MINUTES=510
OUTREACH_BUSINESS_END_MINUTES=1050
OUTREACH_DAILY_SMS_CAP=30
OUTREACH_DAILY_EMAIL_CAP_PER_SENDER=30
OUTREACH_EMAIL_ROTATION_ENABLED=false
OUTREACH_AUTOMATION_BATCH_LIMIT=10

# Political candidate intelligence providers
FEC_API_KEY=your-openfec-api-key
GOOGLE_CIVIC_API_KEY=your-google-civic-api-key
DEMOCRACY_WORKS_API_KEY=your-democracy-works-api-key
BALLOTPEDIA_API_KEY=your-ballotpedia-api-key
BALLOTPEDIA_CANDIDATES_ENDPOINT=/your-licensed-candidates-endpoint
CANDIDATE_INTEL_WEBHOOK_SECRET=change-me
ENABLE_CANDIDATE_SERPAPI=false
ENABLE_CANDIDATE_SERPAPI_DEFAULT_SYNC=false
CANDIDATE_SERPAPI_MIN_REFRESH_HOURS=24

# Prospecting scraper controls
# Default is paused; set to false only when SerpAPI scraping should resume.
SERPAPI_PAUSED=true
SERPAPI_KEY=your-serpapi-key
HUNTER_API_KEY=your-hunter-api-key

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=HomeReach
ENABLE_POLITICAL=false
ENABLE_OPERATIONS_COPILOT=true
ENABLE_AI_INTAKE_AGENT=false

# ─────────────────────────────────────────────
# Internal / Admin
# ─────────────────────────────────────────────
# Comma-separated list of admin email addresses
ADMIN_EMAILS=admin@home-reach.com
